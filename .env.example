# Database
DATABASE_URL=sqlite+aiosqlite:///./flexloop.db

# AI Provider (openai | anthropic | ollama | openai-compatible)
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_API_KEY=your-api-key-here
AI_BASE_URL=
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# AI Review
AI_REVIEW_FREQUENCY=block
AI_REVIEW_BLOCK_WEEKS=6

# Server
HOST=0.0.0.0
PORT=8000
